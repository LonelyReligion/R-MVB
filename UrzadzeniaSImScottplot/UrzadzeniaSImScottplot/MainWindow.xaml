<Window x:Class="UrzadzeniaSImScottplot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UrzadzeniaSImScottplot"
        xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <ScottPlot:WpfPlot x:Name="plot" Grid.Column="0" />

        <Grid Grid.Column="1">
            <Button Content="Dodaj urzadzenie" x:Name="GenerujLosowy" Click="GenerujLosowy_Click" Margin="25,28,272,372"/>
            <Button Content="Generuj pomiary" Margin="282,28,21,372" />

            <Button Content="Wyszukaj srednia" Margin="146,254,146,147" />
            <Button Content="Wyszukaj urzadzenie" Margin="272,253,10,146" />
            <Button Content="Wyszukaj urzadzenia" Margin="10,254,272,147" />
            <TextBlock HorizontalAlignment="Left" Margin="10,299,0,0" TextWrapping="Wrap" VerticalAlignment="Top"><Run Language="pl-pl" Text="Wyniki pomiarów"/></TextBlock>
            <DataGrid HorizontalAlignment="Left" Height="136" Margin="18,81,0,0" VerticalAlignment="Top" Width="361" d:ItemsSource="{d:SampleData ItemCount=5}"/>
        </Grid>

    </Grid>
</Window>
