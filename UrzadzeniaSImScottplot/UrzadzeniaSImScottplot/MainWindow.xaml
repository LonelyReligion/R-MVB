<Window x:Class="UrzadzeniaSImScottplot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UrzadzeniaSImScottplot"
        xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <ScottPlot:WpfPlot x:Name="plot" Grid.Column="0" Margin="10,10,10,10"/>

        <Grid Grid.Column="1">

            <Grid.RowDefinitions>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="3*"/>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="2*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Button Content="Dodaj urzadzenie" x:Name="GenerujLosowy" Click="GenerujLosowy_Click" Height="30" Width="120" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0"/>
                <Button Content="Generuj pomiary" Height="30" Width="120" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"/>
            </Grid>

            <Grid Grid.Row="1"> 
                <DataGrid x:Name="SiatkaUrzadzen" Margin ="10,10,10,10"/>
            </Grid>

            <Grid Grid.Row="2">
                <Button Content="Wyszukaj średnią" Height="30" Width="120" HorizontalAlignment="Left" Margin="10,0,0,0"/>
                <Button x:Name="przycisk_wyszukaj_urzadzenia" Content="Wyszukaj urządzenia" Height="30" Width="120" HorizontalAlignment="Center" Click="przycisk_wyszukaj_urzadzenia_Click"/>
                <Button Content="Wyszukaj wersję/e" Height="30" Width="120" HorizontalAlignment="Right" Margin="0,0,10,0"/>
            </Grid>

            <Grid Grid.Row="3">
                <TextBlock HorizontalAlignment="Left" TextWrapping="Wrap" VerticalAlignment="Top"><Run Language="pl-pl" Text="Wyniki pomiarów"/></TextBlock>
            </Grid>
            
            <Grid Grid.Row="4">
                <DataGrid x:Name="TabelaWynikow"  d:ItemsSource="{d:SampleData ItemCount=5}" Margin="10,10,10,10"/>
            </Grid>
            
        </Grid>
    </Grid>
</Window>
