<Window x:Class="UrzadzeniaSImScottplot.wyszukaj_urzadzenia"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UrzadzeniaSImScottplot"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        mc:Ignorable="d"
        Title="wyszukaj_urzadzenia" Height="350" Width="600"
        >
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="#C9DABA">
            <TextBlock HorizontalAlignment="Left" Margin="10,10,0,10" TextWrapping="Wrap" Text="Uzupełnij współrzędne prostokąta, w którym będą wyszukiwane urządzenia." VerticalAlignment="Top"/>
        </Grid>

        <local:wybor_prostokata x:Name="prostkat" Grid.Row="1"></local:wybor_prostokata>

       <Grid Margin="0,0,0,10" Grid.Row="2">
            <Button x:Name="anuluj" Content="Anuluj" Width="100" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,300,0" Click="anuluj_Click"/>
            <Button x:Name="przeslij" Content="Przeslij" Width="100" Height="20" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="300,0,00,0" Click="przeslij_Click"/>
        </Grid>
        
    </Grid>
</Window>
