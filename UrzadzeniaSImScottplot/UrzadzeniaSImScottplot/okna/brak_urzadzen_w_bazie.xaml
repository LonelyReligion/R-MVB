        <TextBlock Margin="10,10,10,0" TextAlignment="Center" TextWrapping="Wrap" Grid.Row="0" Text="Nie ma urządzeń. Przed wykonaniem zapytania dodaj co najmniej jedno urządzenie." HorizontalAlignment="Center" />
        <Button Margin="0,0,0,10" VerticalAlignment="Bottom" HorizontalAlignment="Center" Width ="100" Height="20" Grid.Row="1" Content="OK" x:Name="OK" Click="OK_Click"/>
    </Grid>
</Window>
