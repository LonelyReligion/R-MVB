<Window x:Class="UrzadzeniaSImScottplot.wyszukaj_srednia"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UrzadzeniaSImScottplot"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        mc:Ignorable="d"
        Title="wyszukaj_srednia" Height="350" Width="600">
    <Grid>
        <TabControl>
            <TabItem Header="Z pomiarów na określonej powierzchni">
                <Grid Background="#FFE5E5E5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="70"/>
                    </Grid.RowDefinitions>


                    <Grid Grid.Row="0" Background="#C9DABA">
                        <TextBlock HorizontalAlignment="Left" Margin="10,10,0,10" TextWrapping="Wrap" Text="Uzupełnij współrzędne prostokąta, dla którego chcesz obliczyć średnią z pomiarów." VerticalAlignment="Top"/>
                    </Grid>
                    
                    <local:wybor_prostokata Grid.Row="1"/>

                    <Grid Grid.Row="2" Margin="0,0,0,10">
                        <Button HorizontalAlignment="Center" Content="Anuluj" Width="100" Height="20" Margin="0,0,300,0" VerticalAlignment="Center"/>
                        <Button HorizontalAlignment="Center" Content="Przeslij" Width="100" Height="20" Margin="300,0,0,0" VerticalAlignment="Center"/>
                    </Grid>
                            
                </Grid>
            </TabItem>
            <TabItem Header="Z pomiarów urządzenia">
                <Grid Background="#FFE5E5E5">

                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <Label Margin="0,0,0,10" HorizontalAlignment="Center" Content="Wybierz ID Urządzenia:" VerticalAlignment="Bottom" Grid.Row="0" />

                    <xctk:IntegerUpDown Margin="0,0,0,10" Height="20" Width="100" VerticalAlignment="Top" Minimum="0" Maximum="{Binding maxID}" Grid.Row="1" Grid.RowSpan="2"/>

                    <Grid Grid.Row="2" Margin="0,0,0,10">
                        <Button HorizontalAlignment="Center" Content="Anuluj" Width="100" Height="20" Margin="0,0,300,0" VerticalAlignment="Center"/>
                        <Button HorizontalAlignment="Center" Content="Przeslij" Width="100" Height="20" Margin="300,0,0,0" VerticalAlignment="Center"/>
                    </Grid>
                    
                </Grid>
            </TabItem>
        </TabControl>

    </Grid>
</Window>
