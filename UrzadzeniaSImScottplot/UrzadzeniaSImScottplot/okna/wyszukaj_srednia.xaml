<Window x:Class="UrzadzeniaSImScottplot.okna.wyszukaj_srednia"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UrzadzeniaSImScottplot.okna"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        mc:Ignorable="d"
        Title="wyszukaj_srednia" Height="450" Width="800">
    <Grid>
        <TabControl>
            <TabItem Header="Z pomiarów na określonej powierzchni">
                <Grid Background="#FFE5E5E5"/>
            </TabItem>
            <TabItem Header="Z pomiarów urządzenia">
                <Grid Background="#FFE5E5E5">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    
                    <Label Grid.Row="0" Content="Wybierz ID Urządzenia" VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
                    <xctk:IntegerUpDown Grid.Row="1" Height="20" Width="100" VerticalAlignment="Top" Minimum="0" Maximum="{Binding maxID}"/>
                </Grid>
            </TabItem>
        </TabControl>

    </Grid>
</Window>
