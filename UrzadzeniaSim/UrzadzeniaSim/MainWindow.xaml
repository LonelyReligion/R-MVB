<Window x:Class="UrzadzeniaSim.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UrzadzeniaSim"
        xmlns:kontrolki="clr-namespace:UrzadzeniaSim.Widok.Kontrolki"
        mc:Ignorable="d"
        Title="Symulacja urządzeń" Height="450" Width="950"
        MinHeight="275" MinWidth="550"
        Name="okno">
    <Grid Name="siatka">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <kontrolki:Siatka x:Name="siatkaWalcowa" Grid.Column="0" znaczono_urzadzenie = "powiedz_o_znaczeniu_panelowi"/>
            <kontrolki:PanelBoczny x:Name="panelBoczny" Grid.Column="1" zmianaStatusuUrzadzenia="przerysuj_siatke"/>
        </Grid>
        <kontrolki:PasekNarzedzi x:Name="pasekNarzedzi" 
                                 zmienionoPowiekszenie="powiedzOtymSiatce" 
                                 zmienionoDokladnoscPoludniki="siatkaZmienPoludniki" 
                                 zmienionoDokladnoscRownolezniki="siatkaZmienRownolezniki"
                                 dodaj_losowe="GenerujLosoweUrzadzenie"
                                 Grid.Row="0"
                                 wyczysc_wszystko="pasekNarzedzi_wyczysc_wszystko"
                                 dodaj_urzadzenie="pasekNarzedzi_dodaj_urzadzenie"
                                 />
    </Grid>
</Window>
