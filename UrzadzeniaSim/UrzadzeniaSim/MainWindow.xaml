<Window x:Class="UrzadzeniaSim.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UrzadzeniaSim"
        xmlns:kontrolki="clr-namespace:UrzadzeniaSim.Widok.Kontrolki"
        mc:Ignorable="d"
        Title="Symulacja urządzeń" Height="450" Width="800"
        MinHeight="225" MinWidth="400"
        Name="okno">
    <Grid Name="siatka" Background="Red">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <kontrolki:PasekNarzedzi x:Name="pasekNarzedzi" Grid.Row="0" zmienionoPowiekszenie="powiedzOtymSiatce"/>
        <kontrolki:Siatka Grid.Row="1"/>
    </Grid>
</Window>
