<Window x:Class="UrzadzeniaSim.Widok.Okna_dialogowe.TworzenieLosowychUrzadzen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:UrzadzeniaSim.Widok.Okna_dialogowe"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        mc:Ignorable="d"
        Title="TworzenieLosowychUrzadzen" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
                
        <TextBlock Grid.Row="0" Text="Podaj liczbę losowych urządzeń, które chcesz wygenerować: "/>
        <xctk:IntegerUpDown Grid.Row="1" Watermark="ile?" Minimum="1"/>
        <Button Grid.Row="2" Width="50" Height="20" Content="Prześlij"/>
    </Grid>
</Window>
