<UserControl x:Class="UrzadzeniaSim.Widok.Kontrolki.PanelBoczny"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UrzadzeniaSim.Widok.Kontrolki"
             mc:Ignorable="d" 
             d:DesignHeight="400" d:DesignWidth="150">
    <Grid Background="#C4DBB8" Name="panel">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
        </Grid>

        <Border Grid.Row="1"
        BorderThickness="1"
        BorderBrush="#5C7D60"/>
        
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <Label x:Name="Label_ID" Content="UrzadzenieID:" Grid.Row="0" Margin="0,10,0,0" FontSize="{Binding Wielkosc_czcionki}"/>
            <Label x:Name="Label_Dlugosc" Content="Długość:" Grid.Row="1" FontSize="{Binding Wielkosc_czcionki}"/>
            <Label x:Name="Label_Szerokosc" Content="Szerokość:" Grid.Row="2" FontSize="{Binding Wielkosc_czcionki}"/>
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>
                <Label x:Name="Label_Status" Grid.Column="0" Content="Status:"  FontSize="{Binding Wielkosc_czcionki}"/>
                <ComboBox x:Name="Statusy" Grid.Column="1" SelectionChanged="Statusy_SelectionChanged" FontSize="{Binding Wielkosc_czcionki}"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
