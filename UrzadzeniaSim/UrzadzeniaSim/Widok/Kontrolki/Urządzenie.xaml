<UserControl x:Class="UrzadzeniaSim.Widok.Kontrolki.Urządzenie"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UrzadzeniaSim.Widok.Kontrolki"
             mc:Ignorable="d" 
             d:DesignHeight="10" d:DesignWidth="10">
    <Grid>
        <Button Name="przycisk" Click="Zaznacz">
            <Button.Template>
                <ControlTemplate>
                    <Grid>
                        <Ellipse
                            x:Name="zaznaczenie"
                            MinWidth="6"
                            MinHeight="6"
                            Stretch="Fill"
                            Fill="Transparent"
                        />
                        <Ellipse
                            x:Name="kolko"
                            Stretch="Fill"
                            MinHeight="5"
                            MinWidth="5"
                            Margin="1,1,1,1"
                            Fill="Blue"
                        />
                    </Grid>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</UserControl>
