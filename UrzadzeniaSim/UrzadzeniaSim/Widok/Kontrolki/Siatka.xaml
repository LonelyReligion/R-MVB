<UserControl x:Class="UrzadzeniaSim.Widok.Kontrolki.Siatka"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UrzadzeniaSim.Widok.Kontrolki"
             mc:Ignorable="d" 
             d:DesignHeight="400" d:DesignWidth="800">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" ClipToBounds="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Canvas Name="plotno" Background="#fffffa" Grid.Column="0" >
                <Canvas.RenderTransform>
                    <ScaleTransform x:Name="skalowanie"/>
                </Canvas.RenderTransform>
            </Canvas>

            <ScrollBar Name="pionowy_scroll"
                       Grid.Column="1"
                       Orientation="Vertical"
                       VerticalAlignment="Stretch"
                       Scroll="przewijanie_pionowe"
                       Visibility="Collapsed"
                       ViewportSize="1"
                       />

        </Grid>

        <ScrollBar Name="poziomy_scroll"
                   Grid.Row="1"
                   Orientation="Horizontal"
                   HorizontalAlignment="Stretch"
                   Scroll="przewijanie_poziome"
                   Visibility="Collapsed"
                   ViewportSize="1"
                   />
    </Grid>
</UserControl>
