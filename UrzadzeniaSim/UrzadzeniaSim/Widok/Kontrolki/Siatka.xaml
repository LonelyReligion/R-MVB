<UserControl x:Class="UrzadzeniaSim.Widok.Kontrolki.Siatka"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:UrzadzeniaSim.Widok.Kontrolki"
             mc:Ignorable="d" 
             d:DesignHeight="400" d:DesignWidth="800">
    <Canvas Grid.Row="1" Name="plotno" Background="White" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Canvas.RenderTransform>
            <ScaleTransform CenterX="{Binding srodekX}" CenterY="{Binding srodekY}" ScaleX="{Binding skalaX}" ScaleY="{Binding skalaY}" />
        </Canvas.RenderTransform>
    </Canvas>
</UserControl>
